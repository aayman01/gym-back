model ProductAttribute {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options ProductAttributeOption[]

  @@index([order])
  @@map("product_attributes")
}

model ProductAttributeOption {
  id          String   @id @default(uuid())
  attributeId String
  value       String   @db.VarChar(255)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attribute         ProductAttribute          @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variantAttributes ProductVariantAttribute[]

  @@unique([attributeId, value])
  @@index([attributeId])
  @@map("product_attribute_options")
}

model Product {
  id                String      @id @default(uuid())
  categoryId        String
  brandId           String?
  slug              String      @unique @db.VarChar(255)
  thumbnailId       String?
  shippingMethodId  String?
  isFeature         Boolean     @default(false)
  rating            Decimal     @default(0.00) @db.Decimal(11, 2)
  lowStockThreshold Int         @default(0)
  tags              String[]    @default([])
  type              ProductType @default(PHYSICAL)
  status            ItemStatus  @default(ACTIVE)
  sellingUnit       SellingUnit @default(PIECE)
  basePrice         Decimal     @default(0.00) @db.Decimal(11, 2)
  taxId             String?
  isTaxIncluded     Boolean     @default(false)
  isFragile         Boolean     @default(false)
  isPerishable      Boolean     @default(false)

  // Inlined content (single language)
  title           String  @db.VarChar(255)
  summary         String? @db.Text
  description     String? @db.Text
  metaTitle       String? @db.Text
  metaKeywords    String? @db.Text
  metaDescription String? @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  category            Category                   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand               Brand?                     @relation(fields: [brandId], references: [id], onDelete: SetNull)
  thumbnail           AdminMedia?                @relation("ProductThumbnail", fields: [thumbnailId], references: [id], onDelete: SetNull)
  shippingMethod      ShippingMethod?            @relation(fields: [shippingMethodId], references: [id], onDelete: SetNull)
  tax                 Tax?                       @relation(fields: [taxId], references: [id], onDelete: SetNull)
  variants            ProductVariant[]
  /// Product-level and variant-level gallery images (canonical gallery table).
  sampleImages        ProductSampleImage[]
  secondaryCategories ProductSecondaryCategory[]
  collectionItems     CollectionItem[]
  cartItems           CartItem[]
  wishlistItems       WishlistItem[]
  orderItems          OrderItem[]

  @@index([status])
  @@index([isFeature])
  @@index([type])
  @@index([rating])
  @@index([categoryId])
  @@index([brandId])
  @@map("products")
}

model ProductVariant {
  id        String     @id @default(uuid())
  productId String
  sku       String     @db.VarChar(100)
  price     Decimal    @db.Decimal(11, 2)
  status    ItemStatus @default(ACTIVE)
  /// Legacy stock count; prefer `inventory.quantityOnHand` when `inventory` is present.
  quantity  Int        @default(0)
  isBase    Boolean    @default(false)
  /// Primary image shown for this variant (separate from gallery `ProductSampleImage` rows).
  displayImageId String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  product               Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  displayImage          AdminMedia?               @relation("ProductVariantDisplayImage", fields: [displayImageId], references: [id], onDelete: SetNull)
  inventory             Inventory?
  inventoryTransactions InventoryTransaction[]
  attributes            ProductVariantAttribute[]
  sampleImages          ProductSampleImage[]
  cartItems             CartItem[]
  wishlistItems         WishlistItem[]
  orderItems            OrderItem[]
  returnRequestItems    ReturnRequestItem[]

  @@unique([productId, sku])
  @@index([productId])
  @@index([status])
  @@index([displayImageId])
  @@map("product_variants")
}

model ProductVariantAttribute {
  id        String   @id @default(uuid())
  variantId String
  optionId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Cascade)
  option  ProductAttributeOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionId])
  @@index([variantId])
  @@index([optionId])
  @@map("product_variant_attributes")
}

model ProductSampleImage {
  id        String   @id @default(uuid())
  productId String
  variantId String?
  imageId   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  image   AdminMedia      @relation(fields: [imageId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([variantId])
  @@map("product_sample_images")
}
