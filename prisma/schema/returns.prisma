model ReturnRequest {
  id              String              @id @default(uuid())
  orderId         String
  customerId      String
  status          ReturnRequestStatus @default(PENDING)
  customerReason  String?             @db.Text
  customerComment String?             @db.Text
  adminComment    String?             @db.Text
  requestedById   String
  reviewedById    String?
  requestedAt     DateTime            @default(now())
  reviewedAt      DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  order       Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer    User                   @relation("ReturnRequestCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  requestedBy User                   @relation("ReturnRequestRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedBy  User?                  @relation("ReturnRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  items       ReturnRequestItem[]
  comments    ReturnRequestComment[]
  events      ReturnRequestEvent[]

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([orderId, status])
  @@map("return_requests")
}

model ReturnRequestItem {
  id                String                  @id @default(uuid())
  returnRequestId   String
  orderItemId       String
  variantId         String?
  quantityRequested Int
  quantityApproved  Int                     @default(0)
  status            ReturnRequestItemStatus @default(PENDING)
  reason            String                  @db.Text
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  returnRequest ReturnRequest   @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem     OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([returnRequestId])
  @@index([orderItemId])
  @@index([variantId])
  @@index([status])
  @@map("return_request_items")
}

model ReturnRequestEvent {
  id              String                 @id @default(uuid())
  returnRequestId String
  eventType       ReturnRequestEventType
  actionBy        ReturnRequestActionBy
  comment         String?                @db.Text
  occurredAt      DateTime               @default(now())

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
  @@index([eventType])
  @@map("return_request_events")
}

model ReturnRequestComment {
  id              String                @id @default(uuid())
  returnRequestId String
  authorId        String
  authorType      ReturnRequestActionBy
  comment         String                @db.Text
  createdAt       DateTime              @default(now())

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  author        User          @relation("ReturnRequestCommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([returnRequestId])
  @@map("return_request_comments")
}
